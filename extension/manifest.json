{
  "manifest_version": 3,
  "name": "CareerPulse AutoFill",
  "description": "Auto-fill job applications with your CareerPulse profile",
  "version": "0.1.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://localhost:8001/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CareerPulse AutoFill"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["http://localhost:8001/*", "http://127.0.0.1:8001/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "commands": {
    "start-fill": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Fill form with CareerPulse"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
